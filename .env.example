# =============================================================================
# ESIC Society AMS — environment template. Copy to `.env` and fill in.
# NEVER commit real secrets. `.env` is gitignored.
# =============================================================================

# --- Database (PostgreSQL) ---
DB_NAME=society_db
DB_USERNAME=society
DB_PASSWORD=society
# JDBC URL used by the backend. For local run use localhost; docker-compose
# overrides this to point at the `db` service automatically.
DB_URL=jdbc:postgresql://localhost:5432/society_db

# --- JWT ---
# Use a long random string (>= 32 chars). Generate e.g. `openssl rand -base64 48`.
JWT_SECRET=change-me-dev-secret-key-please-override-0123456789abcdef
JWT_EXPIRY_MIN=240

# --- App ---
# Public URL of the frontend, used to build password-reset links in emails.
APP_BASE_URL=http://localhost:5173
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Seeded ADMIN account (created on first startup if absent) ---
ADMIN_ACCOUNT_NO=ADMIN001
ADMIN_PASSWORD=Admin@12345
ADMIN_EMAIL=admin@esicsociety.local
# Seed the demo member "Yogesh Kr. Yadav" (A/c 1583) with sample ledger data.
SEED_DEMO=true

# --- Business rule defaults ---
COMPULSORY_DEPOSIT_DEFAULT=1500
LOAN_ANNUAL_RATE_PCT=8

# --- Email / SMTP (provide your real SMTP here) ---
# When MAIL_ENABLED=false, reset/first-login links are logged to the server
# console instead of being emailed (handy for local demos without SMTP).
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@esicsociety.local
